<?xml version="1.0"?>
<iq:manifest version="3" xmlns:iq="http://www.garmin.com/xml/connectiq">
    <iq:application entry="WatchFaceApp" id="55e6fdcf-4cae-42f7-863c-94cf1f98d20d" launcherIcon="@Drawables.LauncherIcon" minApiLevel="3.3.0" name="@Strings.AppName" type="watchface" version="1.0.0">
        <iq:products>
            <iq:product id="fenix6"/>
            <iq:product id="fenix6pro"/>
        </iq:products>
        <iq:permissions>
            <iq:uses-permission id="SensorHistory"/>
            <!-- Background: allows the watch face to run a timer-based service
                 that fetches weather even when the face is not on screen -->
            <iq:uses-permission id="Background"/>
            <!-- Communications: required to make HTTP requests to Open-Meteo -->
            <iq:uses-permission id="Communications"/>
            <!-- Positioning: allows reading GPS coordinates via Position.getInfo()
                 so the background service can fetch weather for your current location -->
            <iq:uses-permission id="Positioning"/>
        </iq:permissions>
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
        <iq:barrels/>
    </iq:application>
</iq:manifest>
