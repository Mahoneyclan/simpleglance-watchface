<?xml version="1.0"?>
<!-- Weather settings for the SimpleGlance Watch Face.
     Users change these via Garmin Connect (mobile app) → My Device → Watch Faces →
     SimpleGlance Watch Face → Settings.

     Latitude and longitude are stored as strings (type="string") rather than numbers
     because Connect IQ settings only provide an alphanumeric keyboard; a type="number"
     field would silently truncate the decimal part.  The Monkey C code converts them
     with .toFloat() when reading. -->
<resources>
    <properties>
        <!-- How often the background service fetches fresh weather (in minutes).
             Lower values give more up-to-date temperatures at the cost of battery. -->
        <property id="refresh_rate" type="number">30</property>

        <!-- Human-readable name for the fixed home location shown in the weather cache. -->
        <property id="home_name" type="string">Home</property>

        <!-- Home location coordinates — decimal degrees, e.g. "-27.3705" or "51.5074".
             Find yours at maps.google.com: right-click any point → copy coordinates. -->
        <property id="home_lat" type="string">-27.3705</property>
        <property id="home_lon" type="string">152.8691</property>
    </properties>

    <settings>
        <setting propertyKey="@Properties.refresh_rate" title="Weather Refresh Interval">
            <settingConfig type="list">
                <listEntry value="15">15 minutes</listEntry>
                <listEntry value="30">30 minutes (default)</listEntry>
                <listEntry value="60">1 hour</listEntry>
            </settingConfig>
        </setting>
        <setting propertyKey="@Properties.home_name" title="Home Location Name">
            <settingConfig type="alphaNumeric" maxLength="32"/>
        </setting>
        <setting propertyKey="@Properties.home_lat" title="Home Latitude">
            <settingConfig type="alphaNumeric" maxLength="12"/>
        </setting>
        <setting propertyKey="@Properties.home_lon" title="Home Longitude">
            <settingConfig type="alphaNumeric" maxLength="12"/>
        </setting>
    </settings>
</resources>
