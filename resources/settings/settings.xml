            <listEntry value="0x00AA00">@Strings.ColorGreen</listEntry>
            <listEntry value="0xFF8000">@Strings.ColorOrange</listEntry>
            <listEntry value="0x8800CC">@Strings.ColorPurple</listEntry>
            <listEntry value="0xFF69B4">@Strings.ColorPink</listEntry>
            <listEntry value="0x888888">@Strings.ColorGrey</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.MinColor" title="@Strings.SettingMinColor">
        <settingConfig type="list">
            <listEntry value="0x000000">@Strings.ColorBlack</listEntry>
            <listEntry value="0xFFFFFF">@Strings.ColorWhite</listEntry>
            <listEntry value="0xFF0000">@Strings.ColorRed</listEntry>
            <listEntry value="0x0000FF">@Strings.ColorBlue</listEntry>
            <listEntry value="0x00AA00">@Strings.ColorGreen</listEntry>
            <listEntry value="0xFF8000">@Strings.ColorOrange</listEntry>
            <listEntry value="0x8800CC">@Strings.ColorPurple</listEntry>
            <listEntry value="0xFF69B4">@Strings.ColorPink</listEntry>
            <listEntry value="0x888888">@Strings.ColorGrey</listEntry>
        </settingConfig>
