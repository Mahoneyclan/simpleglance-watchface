    <setting propertyKey="@Properties.LeftField" title="@Strings.SettingLeftField">
        <settingConfig type="list">
            <listEntry value="0">@Strings.FieldNone</listEntry>
            <listEntry value="1">@Strings.FieldSteps</listEntry>
            <listEntry value="2">@Strings.FieldCalories</listEntry>
            <listEntry value="3">@Strings.FieldDistance</listEntry>
            <listEntry value="4">@Strings.FieldFloors</listEntry>
            <listEntry value="5">@Strings.FieldActiveMin</listEntry>
            <listEntry value="7">@Strings.FieldElevation</listEntry>
        </settingConfig>
    </setting>

    <setting propertyKey="@Properties.RightField" title="@Strings.SettingRightField">
        <settingConfig type="list">
            <listEntry value="0">@Strings.FieldNone</listEntry>
            <listEntry value="1">@Strings.FieldSteps</listEntry>
            <listEntry value="2">@Strings.FieldCalories</listEntry>
            <listEntry value="3">@Strings.FieldDistance</listEntry>
